# Copy to .env and fill in values. Never commit .env.

GOOGLE_API_KEY=
# Optional alias (same AI Studio key)
GEMINI_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it

# Neon Postgres
DATABASE_URL=

# API server port (local). Replit sets its own PORT.
PORT=8787

# Frontend (Vite). Leave BASE_PATH=/ for local.
BASE_PATH=/
API_PROXY_TARGET=http://127.0.0.1:8787
